---
/**
 * BaseLayout — default page shell for every NOH site.
 * Applies brand CSS (v2, Arial), renders Header + Footer
 * with the right domain + compliance context.
 */
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import "./reset.css";
import "./brand.css";

interface Props {
  title: string;
  description?: string;
  domain: "com" | "coza";
  /** Content positioning hint — does NOT change brand chrome (PDF B1) */
  contentType?: "systems" | "clinical" | "subbrand";
  /** True when this page carries regulated clinical content
      (then footer adds the compliance attribution per PDF B9) */
  compliance?: boolean;
  /** HPCSA practice number to inject into the compliance line */
  hpcsaPR?: string;
  /** Optional canonical URL */
  canonical?: string;
  /** Optional hreflang sister URL on the other domain */
  hreflangSister?: { href: string; lang: string };
  /** Optional nav for header */
  nav?: { label: string; href: string }[];
  /** Optional OG image URL */
  ogImage?: string;
  /** OpenGraph type — "website" (default) or "product" for catalogue/product pages */
  ogType?: string;
  /** Which brand leads the header. "noh" (default) or "practice". */
  lead?: "noh" | "practice";
  /** Header CTA override — see Header.astro. */
  cta?: { label: string; href: string; variant?: "solid" | "outline" }[] | false;
}

const {
  title,
  description = "Network One Health — coordinated maternal and women's health care.",
  domain,
  contentType,
  compliance = false,
  hpcsaPR,
  canonical,
  hreflangSister,
  nav = [],
  ogImage,
  ogType = "website",
  lead = "noh",
  cta,
} = Astro.props;

const lang = domain === "coza" ? "en-ZA" : "en";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    {hreflangSister && (
      <link rel="alternate" hreflang={hreflangSister.lang} href={hreflangSister.href} />
    )}

    <!-- Typography: Arial system stack (v2 / CR-002 — Inter dropped, zero external font requests) -->

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <slot name="head" />
  </head>
  <body>
    <Header domain={domain} contentType={contentType} nav={nav} lead={lead} cta={cta} />
    <main>
      <slot />
    </main>
    <Footer domain={domain} compliance={compliance} hpcsaPR={hpcsaPR} />
  </body>
</html>
