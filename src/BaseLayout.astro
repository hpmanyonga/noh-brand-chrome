---
/**
 * BaseLayout — default page shell for every NOH site.
 * Applies brand CSS, Inter from Google Fonts, renders Header + Footer
 * with the right domain + compliance context.
 */
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import "./reset.css";
import "./brand.css";

interface Props {
  title: string;
  description?: string;
  domain: "com" | "coza";
  /** Content positioning hint — does NOT change brand chrome (PDF B1) */
  contentType?: "systems" | "clinical" | "subbrand";
  /** True when this page carries regulated clinical content
      (then footer adds the compliance attribution per PDF B9) */
  compliance?: boolean;
  /** HPCSA practice number to inject into the compliance line */
  hpcsaPR?: string;
  /** Optional canonical URL */
  canonical?: string;
  /** Optional hreflang sister URL on the other domain */
  hreflangSister?: { href: string; lang: string };
  /** Optional nav for header */
  nav?: { label: string; href: string }[];
  /** Optional OG image URL */
  ogImage?: string;
  /** Which brand leads the header. "noh" (default) or "practice". */
  lead?: "noh" | "practice";
}

const {
  title,
  description = "Network One Health — coordinated maternal and women's health care.",
  domain,
  contentType,
  compliance = false,
  hpcsaPR,
  canonical,
  hreflangSister,
  nav = [],
  ogImage,
  lead = "noh",
} = Astro.props;

const lang = domain === "coza" ? "en-ZA" : "en";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    {hreflangSister && (
      <link rel="alternate" hreflang={hreflangSister.lang} href={hreflangSister.href} />
    )}

    <!-- Inter (digital typography per PDF B5) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <slot name="head" />
  </head>
  <body>
    <Header domain={domain} contentType={contentType} nav={nav} lead={lead} />
    <main>
      <slot />
    </main>
    <Footer domain={domain} compliance={compliance} hpcsaPR={hpcsaPR} />
  </body>
</html>
