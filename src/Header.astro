---
/**
 * NOH Header — Network One Health ALWAYS leads (PDF B1 hard rule).
 *
 * Practice name "Dr HP Manyonga and Associates Inc." appears ONLY in the
 * compliance footer — never in chrome or hero copy.
 *
 * Logos: uses the canonical NOH mark (just the symbol) at small sizes for
 * crisp display. The full lockup `noh-colour.svg` is preferred for hero
 * banners and footers; use it via the BrandMark component or directly
 * by URL: cdn.jsdelivr.net/gh/hpmanyonga/noh-brand-chrome@main/assets/noh-colour.svg
 */
import BrandPill from "./BrandPill.astro";
import { callbackUrl, EOI_FORM_URL } from "./urls.js";

interface Props {
  /** Which domain we're on — drives BrandPill direction */
  domain: "com" | "coza";
  /** Content positioning hint — does NOT change brand chrome */
  contentType?: "systems" | "clinical" | "subbrand";
  /** Optional nav items */
  nav?: { label: string; href: string }[];
  /** Home href — defaults to "/" */
  home?: string;
  /** Which brand leads the header. "noh" (default) or "practice"
      (the clinician-owned provider estate: hpmanyonga.co.za + join.). */
  lead?: "noh" | "practice";
  /** Prominent header actions (HP rule 2026-07-11: both funnel doors are
      always visible at the top — patient call-back AND provider EOI).
      Pass false to suppress, or an array to override. */
  cta?: { label: string; href: string; variant?: "solid" | "outline" }[] | false;
}

const { domain, nav = [], home = "/", lead = "noh", cta } = Astro.props;

const patientCta = { label: "Ask us to call you", href: callbackUrl(`header-${domain}`), variant: "solid" };
const providerCta = { label: "Express interest", href: `${EOI_FORM_URL}?source=header-${domain}`, variant: "outline" };
const headerCtas =
  cta === false
    ? []
    : cta ??
      (lead === "practice" ? [providerCta && { ...providerCta, variant: "solid" }, { ...patientCta, variant: "outline" }] : [patientCta, providerCta]);

const CDN = "https://cdn.jsdelivr.net/gh/hpmanyonga/noh-brand-chrome@main/assets";
const brand =
  lead === "practice"
    ? {
        mark: `${CDN}/hpma-colour.png`,
        name: "Dr H P Manyonga & Associates",
        sub: "The Network One Health provider network",
        aria: "Dr H P Manyonga & Associates home",
      }
    : {
        mark: `${CDN}/noh-mark-colour.svg`,
        name: "Network One Health",
        sub: "Coordinated maternal & women's health",
        aria: "Network One Health home",
      };
---

<header class="noh-header">
  <div class="noh-container noh-header__inner">
    <a class="noh-header__brand" href={home} aria-label={brand.aria}>
      <img
        src={brand.mark}
        alt=""
        class="noh-header__mark"
        width="40"
        height="40"
        loading="eager"
      />
      <span class="noh-header__brand-text">
        <span class="noh-header__brand-name">{brand.name}</span>
        <span class="noh-header__brand-sub">{brand.sub}</span>
      </span>
    </a>

    <div class="noh-header__right">
      {headerCtas.map((c) => (
        <a class={`noh-header__cta noh-header__cta--${c.variant ?? "solid"}`} href={c.href} target="_blank" rel="noopener">
          {c.label}
        </a>
      ))}
      <BrandPill domain={domain} />
    </div>
    {nav.length > 0 && (
      <nav class="noh-header__nav" aria-label="Primary">
        {nav.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </nav>
    )}
  </div>
</header>

<style>
  .noh-header {
    background: var(--noh-white);
    border-bottom: 1px solid var(--noh-soft-gray);
    padding: 0.85rem 0;
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .noh-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .noh-header__brand {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--noh-ink);
    text-decoration: none;
    line-height: 1.15;
  }
  .noh-header__brand:hover { text-decoration: none; }
  .noh-header__mark {
    display: block;
    object-fit: contain;
    flex-shrink: 0;
  }
  .noh-header__brand-text { display: flex; flex-direction: column; }
  .noh-header__brand-name {
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--noh-teal);
    letter-spacing: -0.01em;
  }
  .noh-header__brand-sub {
    font-size: 0.72rem;
    color: var(--noh-muted);
    font-weight: 500;
    margin-top: 1px;
  }
  .noh-header__right {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: nowrap;
    margin-left: auto;
  }
  .noh-header__nav {
    flex-basis: 100%;
    padding-top: 0.35rem;
  }
  .noh-header__cta {
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.5rem 1.1rem;
    border-radius: 999px;
    text-decoration: none;
    white-space: nowrap;
  }
  .noh-header__cta--solid {
    background: var(--noh-green);
    color: var(--noh-white);
  }
  .noh-header__cta--outline {
    border: 2px solid var(--noh-green);
    color: var(--noh-green);
    background: transparent;
  }
  .noh-header__cta:hover {
    filter: brightness(0.92);
  }
  .noh-header__nav {
    display: flex;
    gap: 1rem;
    font-size: 0.9rem;
    font-weight: 600;
  }
  .noh-header__nav a { color: var(--noh-ink); }
  .noh-header__nav a:hover { color: var(--noh-teal); }
  @media (max-width: 640px) {
    .noh-header__brand-sub { display: none; }
  }
</style>
