---
/**
 * NOH Footer (PDF B9).
 *
 * Standard footer = teal/green strip, white text:
 *   info@networkonehealth.co.za, WhatsApp bot 071 224 2788 (SWIFT Care
 *   automated line, diary-connected — HP's preferred bot number),
 *   WhatsApp team 066 499 2713 (human-staffed), www.networkonehealth.co.za.
 *   Bot vs team labels are intentional (HP 2026-07-18): patients choose
 *   instant automated answers vs a human. Never drop the bot line.
 *
 * Compliance footer line (only when `compliance` is true, i.e. on regulated
 * clinical content). Canonical wording set by HP 2026-07-10 (supersedes the
 * 2026-05-26 and 2026-06-29 variants) — NOH is the integrator: the practice
 * signs off clinical content and owns the guidelines/tools (IP + know-how);
 * clinical delivery is by local teams under NOH governance. Sites may use
 * different clinical providers, so never write "clinical services provided
 * by". Identified by BHF practice number, never "HPCSA PR"/MP. This framing
 * complies with HPCSA and indemnity requirements:
 *   "A service of Network One Health. Clinical content is signed off by
 *    Dr H P Manyonga & Associates Inc. (BHF practice number 0977357); all
 *    guidelines and tools remain its property. Care at each site is delivered
 *    by your local Network One care team, under Network One clinical
 *    governance."
 *
 * Cross-brand link (the "elegant, non-disruptive" link to the sister domain)
 * sits as a sub-link inside the strip.
 */

interface Props {
  /** Which domain we're on — drives cross-domain link wording */
  domain: "com" | "coza";
  /** Add the regulated-content compliance attribution line */
  compliance?: boolean;
  /** Practice number to inject into the compliance line (if known).
      Prop name kept as `hpcsaPR` for backwards compatibility. */
  hpcsaPR?: string;
}

const { domain, compliance = false, hpcsaPR } = Astro.props;

const year = new Date().getFullYear();

// Canonical compliance footer (HP 2026-07-10). Sign-off + IP ownership sit
// with the practice; delivery sits with local teams under NOH governance —
// wording must survive sites where the practice is not the clinical provider.
const complianceLine = `A service of Network One Health. Clinical content is signed off by Dr H P Manyonga & Associates Inc. (BHF practice number ${hpcsaPR ?? "0977357"}); all guidelines and tools remain its property. Care at each site is delivered by your local Network One care team, under Network One clinical governance.`;

const sister =
  domain === "com"
    ? { label: "Network One Health (SA)", href: "https://hpmanyonga.co.za" }
    : { label: "Dr Howard P Manyonga", href: "https://hpmanyonga.com" };
---

<footer class="noh-footer">
  <div class="noh-footer__strip">
    <div class="noh-container noh-footer__strip-inner">
      <ul class="noh-footer__contacts">
        <li>
          <a href="mailto:info@networkonehealth.co.za">info@networkonehealth.co.za</a>
        </li>
        <li>
          <span class="noh-footer__label">WhatsApp (bot):</span>
          <a href="https://wa.me/27712242788">071 224 2788</a>
        </li>
        <li>
          <span class="noh-footer__label">WhatsApp (team):</span>
          <a href="https://wa.me/27664992713">066 499 2713</a>
        </li>
        <li>
          <a href="https://www.networkonehealth.co.za">www.networkonehealth.co.za</a>
        </li>
      </ul>
      <a class="noh-footer__sister" href={sister.href}>
        Also visit: <strong>{sister.label}</strong> →
      </a>
    </div>
  </div>

  <div class="noh-footer__base noh-container">
    {compliance && <p class="noh-footer__compliance">{complianceLine}</p>}
    <p class="noh-footer__copy">
      &copy; {year} Network One Health.
      <a href="/privacy">Privacy</a> ·
      <a href="/terms">Terms</a>
    </p>
  </div>
</footer>

<style>
  .noh-footer {
    margin-top: 4rem;
    font-size: 0.88rem;
    line-height: 1.6;
  }
  .noh-footer__strip {
    background: var(--noh-green);
    color: var(--noh-white);
    padding: 1.5rem 0;
  }
  .noh-footer__strip a { color: var(--noh-white); text-decoration: none; }
  .noh-footer__strip a:hover { text-decoration: underline; }
  .noh-footer__strip-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .noh-footer__contacts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    font-weight: 500;
  }
  .noh-footer__label {
    opacity: 0.85;
    font-weight: 500;
    margin-right: 0.35rem;
  }
  .noh-footer__sister {
    font-weight: 500;
    opacity: 0.95;
  }
  .noh-footer__base {
    padding: 1.25rem 0 2rem;
    color: var(--noh-muted);
    font-size: 0.78rem;
  }
  .noh-footer__compliance {
    margin: 0 0 0.5rem;
    font-style: italic;
  }
  .noh-footer__copy { margin: 0; }
  .noh-footer__copy a { color: var(--noh-muted); margin: 0 0.25rem; }
  @media (max-width: 640px) {
    .noh-footer__strip-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
