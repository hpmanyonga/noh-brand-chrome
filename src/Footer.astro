---
/**
 * NOH Footer (PDF B9).
 *
 * Standard footer = teal/green strip, white text, 3 items:
 *   info@networkonehealth.co.za, 066 499 2713, www.networkonehealth.co.za
 *
 * Compliance footer line (only when `compliance` is true, i.e. on regulated
 * clinical content). The practice is identified by its Practice Number, NOT an
 * "HPCSA PR" number (HP rule 2026-05-26). The practice is named as the developer
 * of the binding clinical protocols, not necessarily the service provider
 * (HP rule 2026-06-29):
 *   "A service of Network One Health. Clinical protocols developed by
 *    Dr H P Manyonga & Associates Inc. Practice No. 0977357."
 *
 * Cross-brand link (the "elegant, non-disruptive" link to the sister domain)
 * sits as a sub-link inside the strip.
 */

interface Props {
  /** Which domain we're on — drives cross-domain link wording */
  domain: "com" | "coza";
  /** Add the regulated-content compliance attribution line */
  compliance?: boolean;
  /** Practice number to inject into the compliance line (if known).
      Prop name kept as `hpcsaPR` for backwards compatibility. */
  hpcsaPR?: string;
}

const { domain, compliance = false, hpcsaPR } = Astro.props;

const year = new Date().getFullYear();

// Compliance footer. "Clinical protocols developed by" (not "services provided
// by"): NOH may not always provide the service, but its clinical protocols are
// binding for any team in the network. Practice number, no "HPCSA PR" prefix.
const complianceLine = `A service of Network One Health. Clinical protocols developed by Dr H P Manyonga & Associates Inc. Practice No. ${hpcsaPR ?? "xxxxxxx"}.`;

const sister =
  domain === "com"
    ? { label: "Network One Health (SA)", href: "https://hpmanyonga.co.za" }
    : { label: "Dr Howard P Manyonga", href: "https://hpmanyonga.com" };
---

<footer class="noh-footer">
  <div class="noh-footer__strip">
    <div class="noh-container noh-footer__strip-inner">
      <ul class="noh-footer__contacts">
        <li>
          <a href="mailto:info@networkonehealth.co.za">info@networkonehealth.co.za</a>
        </li>
        <li>
          <a href="tel:+27664992713">066 499 2713</a>
        </li>
        <li>
          <a href="https://www.networkonehealth.co.za">www.networkonehealth.co.za</a>
        </li>
      </ul>
      <a class="noh-footer__sister" href={sister.href}>
        Also visit: <strong>{sister.label}</strong> →
      </a>
    </div>
  </div>

  <div class="noh-footer__base noh-container">
    {compliance && <p class="noh-footer__compliance">{complianceLine}</p>}
    <p class="noh-footer__copy">
      &copy; {year} Network One Health.
      <a href="/privacy">Privacy</a> ·
      <a href="/terms">Terms</a>
    </p>
  </div>
</footer>

<style>
  .noh-footer {
    margin-top: 4rem;
    font-size: 0.88rem;
    line-height: 1.6;
  }
  .noh-footer__strip {
    background: var(--noh-green);
    color: var(--noh-white);
    padding: 1.5rem 0;
  }
  .noh-footer__strip a { color: var(--noh-white); text-decoration: none; }
  .noh-footer__strip a:hover { text-decoration: underline; }
  .noh-footer__strip-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .noh-footer__contacts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    font-weight: 500;
  }
  .noh-footer__sister {
    font-weight: 500;
    opacity: 0.95;
  }
  .noh-footer__base {
    padding: 1.25rem 0 2rem;
    color: var(--noh-muted);
    font-size: 0.78rem;
  }
  .noh-footer__compliance {
    margin: 0 0 0.5rem;
    font-style: italic;
  }
  .noh-footer__copy { margin: 0; }
  .noh-footer__copy a { color: var(--noh-muted); margin: 0 0.25rem; }
  @media (max-width: 640px) {
    .noh-footer__strip-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
