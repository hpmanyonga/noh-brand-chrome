---
/**
 * BrandPill — small cross-brand link at top of every page.
 *
 * Per noh-design-os/brand_architecture.yaml (HARD GATE):
 *   - gynaecology content → front brand = "Dr HP Manyonga & Associates",
 *     managing = "Network One Health" (label: "Managed by Network One Health")
 *   - maternity content → front brand = "Network One Health",
 *     secondary = "Dr HP Manyonga & Associates" (regulatory)
 *
 * On hpmanyonga.com pages this surfaces the NOH operating link.
 * On hpmanyonga.co.za pages this surfaces the clinician credential link.
 */

interface Props {
  /** Which domain we're rendering on — determines pill direction */
  domain: "com" | "coza";
  /** Optional override for label */
  label?: string;
  /** Optional override for target href */
  href?: string;
}

const { domain, label, href } = Astro.props;

const defaults = {
  com: {
    label: "Operating as Network One Health in South Africa",
    href: "https://hpmanyonga.co.za",
  },
  coza: {
    label: "Founded by Dr H P Manyonga",
    href: "https://hpmanyonga.com/about",
  },
};

const pillLabel = label ?? defaults[domain].label;
const pillHref = href ?? defaults[domain].href;
---

<a class="noh-brand-pill" href={pillHref} aria-label={pillLabel}>
  <span class="noh-brand-pill__label">{pillLabel}</span>
  <span class="noh-brand-pill__arrow" aria-hidden="true">→</span>
</a>

<style>
  .noh-brand-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--noh-cream);
    color: var(--noh-ink);
    border: 1px solid var(--noh-green);
    border-radius: 999px;
    padding: 0.25rem 0.75rem;
    font-size: 0.78rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s ease;
  }
  .noh-brand-pill:hover {
    background: var(--noh-green);
    color: var(--noh-cream);
    text-decoration: none;
  }
  .noh-brand-pill__arrow {
    font-weight: 700;
  }
</style>
