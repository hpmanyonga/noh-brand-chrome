---
/**
 * BrandPill — small cross-domain link in the header.
 *
 * Per PDF B1: Network One Health leads everywhere. This pill is navigation
 * to the sister domain — does NOT name the practice (practice name lives in
 * the compliance footer only).
 *
 * On .com we surface the ZA service site. On .co.za we surface the
 * clinician brand. The cross-domain bridge is the "elegant non-disruptive"
 * link the brand owner asked for.
 */

interface Props {
  domain: "com" | "coza";
  label?: string;
  href?: string;
}

const { domain, label, href } = Astro.props;

const defaults = {
  com: {
    label: "Visit NOH South Africa",
    href: "https://hpmanyonga.co.za",
  },
  coza: {
    label: "About Dr HP Manyonga",
    href: "https://hpmanyonga.com/about",
  },
};

const pillLabel = label ?? defaults[domain].label;
const pillHref = href ?? defaults[domain].href;
---

<a class="noh-brand-pill" href={pillHref}>
  <span class="noh-brand-pill__label">{pillLabel}</span>
  <span class="noh-brand-pill__arrow" aria-hidden="true">→</span>
</a>

<style>
  .noh-brand-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: transparent;
    color: var(--noh-teal);
    border: 1px solid var(--noh-teal);
    border-radius: 999px;
    padding: 0.3rem 0.8rem;
    font-size: 0.78rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .noh-brand-pill:hover {
    background: var(--noh-teal);
    color: var(--noh-white);
    text-decoration: none;
  }
</style>
